{
  "bots": [
    {
      "name": "allow-git-clients",
      "action": "ALLOW",
      "expression": {
        "all": [
          "userAgent.startsWith(\"git/\") || userAgent.contains(\"libgit\")",
          "\"Git-Protocol\" in headers && headers[\"Git-Protocol\"] == \"version=2\""
        ]
      }
    }
  ],
  "metrics": {
    "bind": ":9090",
    "network": "tcp"
  }
}
